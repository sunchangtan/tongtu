# 本地用户配置
.claude/settings.local.json

# 项目规范文件需要入库（覆盖全局 gitignore 的忽略规则）
!CLAUDE.md

# 构建产物
build/
*.xcframework
core-bridge/.gomobile-cache/

# macOS
.DS_Store

# Go
core-bridge/vendor/

# Xcode
xcuserdata/
DerivedData/

# Xcode 工程（由 xcodegen 从 project.yml 生成）
ios-poc/*.xcodeproj
ios-poc/DerivedData/

# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
devtools_options.yaml

# IntelliJ / Android Studio（Flutter 生成）
*.iml
*.ipr
*.iws
.idea/

# Flutter iOS 生成物（CocoaPods 与构建中间产物）
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/ephemeral/
ios/Pods/
ios/.symlinks/
